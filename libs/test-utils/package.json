{
	"name": "@vonage/vivid-test-utils",
	"version": "5.18.0",
	"type": "module",
	"exports": {
		"./dom": {
			"types": "./dist/dom.d.ts",
			"import": "./dist/dom.js",
			"require": "./dist/dom.cjs"
		},
		"./playwright": {
			"types": "./dist/playwright.d.ts",
			"import": "./dist/playwright.js",
			"require": "./dist/playwright.cjs"
		},
		"./cypress": {
			"types": "./dist/cypress.d.ts",
			"import": "./dist/cypress.js",
			"require": "./dist/cypress.cjs"
		},
		"./jsdom-polyfill": {
			"types": "./dist/jsdom-polyfill.d.ts",
			"import": "./dist/jsdom-polyfill.js",
			"require": "./dist/jsdom-polyfill.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "tsx scripts/codegen.ts",
		"build": "vite build",
		"cy": "concurrently -k -s first -n VITE,TEST \"pnpm vite src/tests/cases -c ./vite.config.ts --host\" \"pnpm wait-on http://localhost:5173 && pnpm cypress run\"",
		"cy:ui": "cypress open",
		"e2e": "concurrently -k -s first -n VITE,TEST \"pnpm vite src/tests/cases -c ./vite.config.ts --host\" \"pnpm wait-on http://localhost:5173 && pnpm playwright test\"",
		"e2e:ui": "playwright test --ui",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage && relativize-coverage .",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tools.json"
	},
	"dependencies": {
		"@testing-library/user-event": "catalog:",
		"@vonage/vivid": "workspace:^",
		"change-case": "catalog:"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@repo/eslint-config": "workspace:*",
		"@repo/metadata-extractor": "workspace:*",
		"@repo/shared": "workspace:*",
		"@repo/tools": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/vitest-config": "workspace:*",
		"@repo/wrapper-gen": "workspace:*",
		"@types/node": "catalog:",
		"@vitejs/plugin-vue": "catalog:",
		"@vonage/vivid-vue": "workspace:*",
		"@vue/test-utils": "^2.4.10",
		"concurrently": "catalog:",
		"cypress": "^15.14.2",
		"tsx": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"vue": "catalog:vue3",
		"wait-on": "catalog:"
	}
}
