// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderComponentTypes > should render a type definitions file 1`] = `
"
import type { VwcExampleComponentElement, ButtonSize } from '@vonage/vivid';
import type { IconId } from '../icons';

export interface VExampleComponentEvents {
	
				/**
 * This is an example event
 */
				'example-event': Event & {
			currentTarget: VwcExampleComponentElement
		},

				
				'input': Event & {
			currentTarget: VwcExampleComponentElement
		},

				/**
 * This is a change event
 */
				'change': Event & {
			currentTarget: VwcExampleComponentElement
		},

				
				'input:start': CustomEvent<{a: string | number}> & {
			currentTarget: VwcExampleComponentElement
		},

				/**
 * Fires when the modelValue value changes
 */
				'update:modelValue': string,

				/**
 * Fires when the sameEvent value changes
 */
				'update:sameEvent': string,

				/**
 * Fires when the start value changes
 */
				'update:start': string
}

export interface VExampleComponentProps {
	/**
 * This is an example prop
 */
        exampleProp?: string,
/**
 * This is an example prop
 */
        sameEvent?: string,

        typeUnion?: string | number,

        iconType?: IconId,

        value?: string,

        modelValue?: string,

        start?: string,

        forcedDomProp?: string | HTMLElement,

        booleanProp?: boolean,

        importedType?: ButtonSize,

        externalType?: any
	
				/** Modifiers for the modelValue v-model */
				modelModifiers?: { trim?: true; number?: true; lazy?: true },

				/** Modifiers for the sameEvent v-model */
				sameEventModifiers?: { trim?: true; number?: true },

				/** Modifiers for the start v-model */
				startModifiers?: { trim?: true; number?: true }
	
				/**
 * This is an example event
 */
				'onExampleEvent'?: (event: VExampleComponentEvents['example-event']) => void,

				
				'onInput'?: (event: VExampleComponentEvents['input']) => void,

				/**
 * This is a change event
 */
				'onChange'?: (event: VExampleComponentEvents['change']) => void,

				
				'onInput:start'?: (event: VExampleComponentEvents['input:start']) => void,

				/**
 * Fires when the modelValue value changes
 */
				'onUpdate:modelValue'?: (event: VExampleComponentEvents['update:modelValue']) => void,

				/**
 * Fires when the sameEvent value changes
 */
				'onUpdate:sameEvent'?: (event: VExampleComponentEvents['update:sameEvent']) => void,

				/**
 * Fires when the start value changes
 */
				'onUpdate:start'?: (event: VExampleComponentEvents['update:start']) => void
}
"
`;
