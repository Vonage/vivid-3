{
  "text": {
    "body": {
      "font-family": {
        "$type": "fontFamily",
        "$value": "{text.font-family.sans-serif}",
        "$description": "The font family used for all body text."
      },
      "font-stretch": {
        "$type": "number",
        "$value": "{text.font-stretch.ultra-condensed}",
        "$description": "The font stretch applied to all body text."
      },
      "sm": {
        "DEFAULT": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{text.body.font-family}",
            "fontSize": "{text.font-size.300}",
            "lineHeight": "{text.line-height.400}",
            "fontWeight": "{text.font-weight.400}",
            "fontStretch": "{text.body.font-stretch}"
          },
          "$description": "A small body size for captions, helper text, and secondary UI text."
        },
        "font-size": {
          "$type": "dimension",
          "$value": "{text.font-size.300}",
          "$description": "Font size for sm body."
        },
        "line-height": {
          "$type": "dimension",
          "$value": "{text.line-height.400}",
          "$description": "Line height for sm body."
        },
        "font-weight": {
          "$type": "number",
          "$value": "{text.font-weight.400}",
          "$description": "Font weight for sm body."
        }
      },
      "md": {
        "DEFAULT": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{text.body.font-family}",
            "fontSize": "{text.font-size.350}",
            "lineHeight": "{text.line-height.500}",
            "fontWeight": "{text.font-weight.400}",
            "fontStretch": "{text.body.font-stretch}"
          },
          "$description": "The default body size for paragraphs and general UI text."
        },
        "font-size": {
          "$type": "dimension",
          "$value": "{text.font-size.350}",
          "$description": "Font size for md body."
        },
        "line-height": {
          "$type": "dimension",
          "$value": "{text.line-height.500}",
          "$description": "Line height for md body."
        },
        "font-weight": {
          "$type": "number",
          "$value": "{text.font-weight.400}",
          "$description": "Font weight for md body."
        }
      },
      "lg": {
        "DEFAULT": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{text.body.font-family}",
            "fontSize": "{text.font-size.400}",
            "lineHeight": "{text.line-height.600}",
            "fontWeight": "{text.font-weight.300}",
            "fontStretch": "{text.body.font-stretch}"
          },
          "$description": "A large body size for high-emphasis content such as lead or important paragraphs and highlighted UI text."
        },
        "font-size": {
          "$type": "dimension",
          "$value": "{text.font-size.400}",
          "$description": "Font size for lg body."
        },
        "line-height": {
          "$type": "dimension",
          "$value": "{text.line-height.600}",
          "$description": "Line height for lg body."
        },
        "font-weight": {
          "$type": "number",
          "$value": "{text.font-weight.300}",
          "$description": "Font weight for lg body."
        }
      }
    }
  }
}
