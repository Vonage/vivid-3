{
  "vivid/text/code/inline": {
    "$type": "typography",
    "$value": {
      "fontFamily": "{vivid/text/font-family/sans-serif-monospace}",
      "fontSize": "{vivid/text/font-size/sm}",
      "lineHeight": "{vivid/text/line-height/2xs}",
      "fontWeight": "{vivid/text/weight/normal}",
      "fontStyle": "{vivid/text/font-style/ultra-condensed}"
    },
    "$description": "Code text style for medium emphasis content, such as inline code snippets and preformatted text."
  },
  "vivid/text/code/block": {
    "$type": "typography",
    "$value": {
      "fontFamily": "{vivid/text/font-family/sans-serif-monospace}",
      "fontSize": "{vivid/text/font-size/xs}",
      "lineHeight": "{vivid/text/line-height/3xs}",
      "fontWeight": "{vivid/text/weight/normal}",
      "fontStyle": "{vivid/text/font-style/ultra-condensed}"
    },
    "$description": "Code text style for medium emphasis content, such as inline code snippets and preformatted text."
  }
}