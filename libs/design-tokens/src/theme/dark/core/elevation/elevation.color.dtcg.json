{
	"shadow": {
			"0": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 1, "offsetY": 0, "blur": 0, "spread": 0, "color": "{color.border.muted}" },
					{ "offsetX": 0, "offsetY": 1, "blur": 0, "spread": 0, "color": "{color.border.muted}" },
					{ "offsetX": 0, "offsetY": -1, "blur": 0, "spread": 0, "color": "{color.border.muted}" },
					{ "offsetX": -1, "offsetY": 0, "blur": 0, "spread": 0, "color": "{color.border.muted}" }
				],
				"$description": "No shadow, just a muted border to separate elements from the background."
			},
			"100": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 1, "blur": 4, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 1, "blur": 2, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 2, "blur": 1, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "Minimal elevation for components resting just above the surface, such as cards and input fields."
			},
			"200": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 2, "blur": 8, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 2, "blur": 4, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 4, "blur": 4, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "Low elevation for interactive components such as buttons and chips that require a slight lift."
			},
			"300": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 2, "blur": 16, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 8, "blur": 8, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 4, "blur": 4, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "Medium elevation for floating elements such as dropdowns and tooltips."
			},
			"400": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 4, "blur": 24, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 12, "blur": 16, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 6, "blur": 8, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "Raised elevation for dialogs and modals that overlay the main content."
			},
			"500": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 6, "blur": 32, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 16, "blur": 24, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 8, "blur": 12, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "High elevation for side panels and navigation drawers."
			},
			"600": {
				"$type": "shadow",
				"$value": [
					{ "offsetX": 0, "offsetY": 12, "blur": 48, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 24, "blur": 32, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } },
					{ "offsetX": 0, "offsetY": 12, "blur": 16, "spread": 0, "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.25, "hex": "#00000040" } }
				],
				"$description": "Maximum elevation for full-screen overlays and the topmost layer of the UI stack."
			}
		},
		"surface-gradient-alpha": {
			"0": {
				"$type": "string",
				"$value": "{color.alphahex.100}"
			},
			"100": {
				"$type": "string",
				"$value": "{color.alphahex.06}"
			},
			"200": {
				"$type": "string",
				"$value": "{color.alphahex.08}"
			},
			"300": {
				"$type": "string",
				"$value": "{color.alphahex.10}"
			},
			"400": {
				"$type": "string",
				"$value": "{color.alphahex.12}"
			},
			"500": {
				"$type": "string",
				"$value": "{color.alphahex.14}"
			},
			"600": {
				"$type": "string",
				"$value": "{color.alphahex.16}"
			}
		}
}
