{
	"name": "vivid-nx",
	"version": "0.0.0",
	"private": true,
	"repository": "github:Vonage/vivid-3",
	"license": "MIT",
	"scripts": {
		"build": "turbo run build",
		"fetch": "turbo run fetch",
		"format": "prettier --experimental-cli --write .",
		"format:check": "prettier --experimental-cli --check .",
		"lint": "turbo run lint stylelint",
		"lint:fix": "turbo run lint:fix stylelint:fix",
		"start": "turbo run dev --filter=@repo/docs --filter=@vonage/vivid --filter=@repo/styles",
		"test": "turbo run test:coverage && istanbul-merge ./libs/*/coverage/coverage-final.json ./apps/*/coverage/coverage-final.json --out .nyc_output/coverage.json && nyc report && nyc check-coverage",
		"test:ui": "turbo run @vonage/vivid#e2e:docker:ui",
		"typecheck": "turbo run typecheck"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@prettier/plugin-oxc": "^0.1.4",
		"@vitest/coverage-v8": "catalog:",
		"@vitest/ui": "catalog:",
		"istanbul-merge": "catalog:",
		"nyc": "catalog:",
		"prettier": "catalog:",
		"prettier-plugin-packagejson": "catalog:",
		"stylelint": "catalog:",
		"tsx": "catalog:",
		"turbo": "^2.9.12",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "catalog:"
	},
	"packageManager": "pnpm@10.28.2",
	"engines": {
		"node": ">=20.19.0",
		"pnpm": ">=10.23.0"
	}
}
