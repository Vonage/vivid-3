{% extends './page.njk' %}
{% set title = pageTitle or component.concept %}


{% block banner %}
	{% if (component.status == "alpha") %}
		<vwc-banner class="banner" text="ALPHA: If you need this component, please contact the Vivid team to co-ordinate acceptence testing" connotation="warning"></vwc-banner>
	{% endif %}
	{% if (component.status == "underlying") %}
		<vwc-banner class="banner" text="Underlying: this component is only used by other components and not intended to be used by authors outside the Vivid team" connotation="information"></vwc-banner>
	{% endif %}
{% endblock %}

{% block aside %}
		{% include '../_includes/toc.njk' %}
{% endblock %}

{% block content %}
	{% if component.documentation | hasAny("variations", "guidelines", "useCases", "accessibility") %}
		<h1>{{ component.concept }}</h1>
		<p>{{ component.description }}</p>
		<div class="components-header" id="components-header">
			<nav>
				<ul>
					{% if component.documentation | has("variations") %}
						<li><a href="/components/{{ component.slug }}/" {% if ("/components/" + (component.slug) + "/") == page.url %} aria-current="page" {% endif %}>Variations</a></li>
					{% endif %}
					{% if component.documentation | has("guidelines") %}
						<li><a href="/components/{{ component.slug }}/guidelines/" {% if ("/components/" + (component.slug) + "/guidelines/") == page.url %} aria-current="page" {% endif %}>Guidelines</a></li>
					{% endif %}

					{% if component.documentation | has("code") %}
						<li><a href="/components/{{ component.slug }}/code/" {% if ("/components/" + (component.slug) + "/code/") == page.url %} aria-current="page" {% endif %}>Code</a></li>
					{% endif %}

					{% if component.documentation | has("useCases") %}
						<li><a href="/components/{{ component.slug }}/use-cases/" {% if ("/components/" + (component.slug) + "/use-cases/") == page.url %} aria-current="page" {% endif %}>Use Cases</a></li>
					{% endif %}

					{% if component.documentation | has("accessibility") %}
						<li><a href="/components/{{ component.slug }}/accessibility/" {% if ("/components/" + (component.slug) + "/accessibility/") == page.url %} aria-current="page" {% endif %}>Accessibility</a></li>
					{% endif %}
				</ul>
			</nav>
		</div>
	{% endif %}

	{{ content | safe }}
{% endblock %}
