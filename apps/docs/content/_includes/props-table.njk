{% if metadata.props and metadata.props | length > 0 %}
	<h3>Properties</h3>
	<table>
		<thead>
			<tr>
				<th>Property</th>
				<th>Type</th>
				<th>Default</th>
				<th>Description</th>
			</tr>
		</thead>
		<tbody>
			{% for prop in metadata.props %}
			<tr>
				<td><strong>{{ prop.name }}</strong></td>
				<td><code>{{ prop.type }}</code></td>
				<td>{{ prop.default | default('') }}</td>
				<td>{{ prop.description | default('') }}</td>
			</tr>
			{% endfor %}
		</tbody>
	</table>
{% endif %}
