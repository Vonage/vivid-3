<style>
	.control-spacing-token-preview {
		position: relative;
		display: inline-flex;
		align-items: center;
		border: 1px solid var(--vvd-color-neutral-400);
		border-radius: 6px;
	}

	.control-spacing-token-preview .control-icon {
		display: inline-block;
		width: 0.75rem;
		height: 0.75rem;
		background-color: var(--vvd-color-neutral-600);
		border-radius: 4px;
	}

	.control-display {
		display: inline-block;
		position: absolute;
		background-color: var(--vvd-color-cta-200);
		border: 1px solid color var(--vvd-color-cta-400);
	}

	.control-display.prop-gap {
		inset-inline-start: calc(var(--_padding-inline) + 0.75rem);
		inset-block-start: 0;
		inset-block-end: 0;
		inline-size: var(--_gap);
	}

	.control-display.prop-padding-inline {
		z-index: -1;
		width: 100%;
		height: 100%;
		inset: 0;
		background: transparent;
		border: 0;
	}

	.control-display.prop-padding-inline::before,
	.control-display.prop-padding-inline::after {
		content: '';
		display: inline-block;
		position: absolute;
		inset-block: 0;
		inline-size: var(--_padding-inline);
		background-color: var(--vvd-color-cta-200);
		border: 1px solid color var(--vvd-color-cta-400);
	}

	.control-display.prop-padding-inline::before {
		inset-inline-start: 0;
	}

	.control-display.prop-padding-inline::after {
		inset-inline-end: 0;
	}

	.control-display.prop-block-size {
		z-index: -1;
		width: 100%;
		height: 100%;
		inset: 0;
	}
</style>