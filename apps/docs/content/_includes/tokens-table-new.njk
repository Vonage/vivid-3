		<vwc-table-row>
			<vwc-table-header-cell style="width: 120px;">Preview</vwc-table-header-cell>
			<vwc-table-header-cell class="token-name">Token</vwc-table-header-cell>
			<vwc-table-header-cell class="px">Description</vwc-table-header-cell>
		</vwc-table-row>
	</vwc-table-head>
	<vwc-table-body>
		{% for item in list %}
			<vwc-table-row>
				<vwc-table-cell>
					<div class="space-preview" style="inline-size: {{ item.preview }}; block-size: {{ item.preview }};"></div>
				</vwc-table-cell>
				<vwc-table-cell><code>{{ item.css | replace('viv-size-', '') }}</code></vwc-table-cell>
				<vwc-table-cell>{{ item.description }}</vwc-table-cell>
			</vwc-table-row>
		{% endfor %}
	</vwc-table-body>
</vwc-table>
{% endmacro %}

<style>
	.align-number {
		text-align: right;
	}
	.token-name {
		width: 220px;
	}
	.space-preview {
		height: 16px;
		background-color: var(--vvd-color-cta-500);
	}
</style>

{% macro typescaleTable(list) %}
<vwc-table>
	<vwc-table-head>
		<vwc-table-row>
			<vwc-table-header-cell style="width: 165px;">Token</vwc-table-header-cell>
			<vwc-table-header-cell style="width: 45%">Preview</vwc-table-header-cell>
			<vwc-table-header-cell>Description</vwc-table-header-cell>
		</vwc-table-row>
	</vwc-table-head>
	<vwc-table-body>
		{% for item in list | reverse %}
			{% if item.type == 'typography' %}
				<vwc-table-row>
					<vwc-table-cell style="vertical-align: top;"><code>{{ item.css | replace('text-', '') }}</code></vwc-table-cell>
					<vwc-table-cell style="vertical-align: top;">
						{% set fontValue = item.preview.fontWeight ~ ' ' ~ item.preview.fontStretch ~ ' ' ~ item.preview.fontSize ~ '/' ~ item.preview.lineHeight ~ ' ' ~ item.preview.fontFamily %}
						<div style="font: {{ fontValue }}">The quick brown fox jumps over the lazy dog</div>
					</vwc-table-cell>
					<vwc-table-cell style="vertical-align: top;">{{ item.description }}</vwc-table-cell>
				</vwc-table-row>
			{% endif %}
		{% endfor %}
	</vwc-table-body>
</vwc-table>
{% endmacro %}

{% macro colorTokenTable(list, headingText, headingLevel = 3) %}
{{ heading(headingText, headingLevel) }}
<vwc-table>
	<vwc-table-head>
		<vwc-table-row>
			<vwc-table-header-cell></vwc-table-header-cell>
			<vwc-table-header-cell>Token</vwc-table-header-cell>
			<vwc-table-header-cell>Description</vwc-table-header-cell>
			<vwc-table-header-cell>Output value</vwc-table-header-cell>
		</vwc-table-row>
	</vwc-table-head>
	<vwc-table-body>
		{% for item in list %}
			<vwc-table-row>
				<vwc-table-cell style="width: 4rem;">
					{{ colorTokenPreview(item) }}
				</vwc-table-cell>
				<vwc-table-cell style="width: 18rem;"><code>{{ item.css | replace('viv-color-', '') | replace('action-', '') }}</code></vwc-table-cell>
				<vwc-table-cell>{{ item.description }}</vwc-table-cell>	
				<vwc-table-cell style="width: 8rem;"><code>{{ item.preview }}</code></vwc-table-cell>
			</vwc-table-row>
		{% endfor %}
	</vwc-table-body>
</vwc-table>
<!-- <pre>{{ list | json }}</pre> -->
{% endmacro %}

{% macro colorTokenPreview(item) %}
	{% if 'text' in item.name %}
		<div class="color-token-preview-text">
			<vwc-tooltip text="{{ item.preview }}" placement="left">
				<div slot="anchor" class="color-token-preview-text" style="color: {{ item.preview }}; background-color: contrast-color({{ item.preview }})">Aa</div>
			</vwc-tooltip>
		</div>
	{% elif '.bg' in item.name %}
		<div class="color-token-preview-bg">
			<vwc-tooltip text="{{ item.preview }}" placement="left">
				<div slot="anchor" style="background-color: {{ item.preview }}; border: 1px solid light-dark(var(--vvd-color-neutral-200), transparent)"></div>
			</vwc-tooltip>
		</div>
	{% elif '.border' in item.name %}
		<div class="color-token-preview-border">
			<vwc-tooltip text="{{ item.preview }}" placement="left">
				<div slot="anchor" class="color-token-preview-border" style="border: 2px solid {{ item.preview }};"></div>
			</vwc-tooltip>	
		</div>
	{% else %}
		<pre>{{ item | json }}</pre>
	{% endif %}
{% endmacro %}

<style>
	.color-token-preview-bg, .color-token-preview-border {
		position: relative;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 2px;
	}

	.color-token-preview-text {
		font-size: 1.25rem;
		font-weight: 500;
		line-height: 2rem;
		display: inline-block;
		padding: 0 0.125rem;
		border-radius: 4px;
	}

	.color-token-preview-bg::before {
    position: absolute;
    z-index: 0;
		background-color: #f0f0f0;
    background-image: linear-gradient(45deg, var(--vvd-color-neutral-800) 25%, transparent 25%), linear-gradient(135deg, var(--vvd-color-neutral-800) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, var(--vvd-color-neutral-800) 75%), linear-gradient(135deg, transparent 75%, var(--vvd-color-neutral-800) 75%);
    background-position: 0 0, 8px 0, 8px -8px, 0 8px;
    background-size: 16px 16px;
    content: "";
    inset: 0;
    opacity: 1;
	}
	.color-token-preview-bg div {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		width: 100%;
		height: 100%;
		z-index: 1;
	}
</style>

{% macro tokenReferenceTable(groups) %}
<vwc-table>
	<vwc-table-head>
		<vwc-table-row>
			<vwc-table-header-cell style="width: 80px;"></vwc-table-header-cell>
			<vwc-table-header-cell>Token</vwc-table-header-cell>
			<vwc-table-header-cell>Description</vwc-table-header-cell>
		</vwc-table-row>
	</vwc-table-head>
	<vwc-table-body>
		{% for group in groups %}
			{% for item in group %}
				<vwc-table-row>
					<vwc-table-cell>
						{% if item.category == 'color' %}
							{{ colorTokenPreview(item) }}
						{% elif item.category == 'text' %}
							{{ textTokenPreview(item) }}
						{% endif %}
					</vwc-table-cell>
					<vwc-table-cell style="width: 18rem;"><code>{{ item.css | replace('', '') }}</code></vwc-table-cell>
					<vwc-table-cell>{{ item.description }}</vwc-table-cell>
				</vwc-table-row>
			{% endfor %}
		{% endfor %}
	</vwc-table-body>
</vwc-table>
{% endmacro %}

{% macro textTokenPreview(item) %}
	<!--pre>{{ item | json }}</pre-->
	{% if 'font-family' in item.name %}
		<vwc-tooltip text="{{ item.preview }}" placement="left">
			<div slot="anchor" class="text-token-font-family" style="font-family: {{ item.preview }}">Aa</div>
		</vwc-tooltip>
	{% elif 'font-size' in item.name %}
		<vwc-tooltip text="{{ item.preview }}" placement="left">
			<div slot="anchor" class="text-token-font-size" style="font-size: {{ item.preview }}">Aa</div>
		</vwc-tooltip>
	{% elif 'font-stretch' in item.name %}
		<vwc-tooltip text="{{ item.preview }}" placement="left">
			<div slot="anchor" class="text-token-font-stretch" style="font-stretch: {{ item.preview }}">Aa</div>
		</vwc-tooltip>
	{% elif 'line-height' in item.name %}
		<vwc-tooltip text="{{ item.preview }}" placement="left">
			<div slot="anchor" class="text-token-line-height" style="line-height: {{ item.preview }}">A<br />a</div>
		</vwc-tooltip>
	{% elif 'font-weight' in item.name %}
		<vwc-tooltip text="{{ item.preview }}" placement="left">
			<div slot="anchor" class="text-token-font-weight" style="font-weight: {{ item.preview }}">Aa</div>
		</vwc-tooltip>
	{% else %}
		{% set fontValue = item.preview.fontWeight ~ ' ' ~ item.preview.fontStretch ~ ' ' ~ item.preview.fontSize ~ '/' ~ item.preview.lineHeight ~ ' ' ~ item.preview.fontFamily %}
		<vwc-tooltip text="{{ fontValue }}" placement="left">
			<div slot="anchor" class="text-token-compound" style="font: {{ fontValue }}">Aa</div>
		</vwc-tooltip>
	{% endif %}
{% endmacro %}

<style>
	.text-token-font-family, .text-token-font-stretch , .text-token-font-weight {
		font-size: 1.2rem;
	}
</style>

