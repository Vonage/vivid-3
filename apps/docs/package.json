		"@codemirror/state": "catalog:",
		"@codemirror/theme-one-dark": "catalog:",
		"@codemirror/view": "catalog:",
		"@playwright/test": "catalog:",
		"@repo/eslint-config": "workspace:*",
		"@repo/shared": "workspace:*",
		"@repo/stylelint-config": "workspace:*",
		"@repo/tokens": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/vitest-config": "workspace:*",
		"@types/jsdom": "catalog:",
		"@types/lodash": "catalog:",
		"@types/markdown-it": "catalog:",
		"@types/markdown-table": "catalog:",
		"@types/node-fetch": "catalog:",
