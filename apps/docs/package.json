{
	"name": "@repo/docs",
	"private": true,
	"scripts": {
		"prebuild": "rm -rf .11ty-vite dist",
		"build": "eleventy",
		"postbuild": "pagefind --site dist",
		"predev": "rm -rf .11ty-vite dist",
		"dev": "eleventy --serve",
		"e2e": "playwright test",
		"e2e:docker": "PW_TEST_CONNECT_WS_ENDPOINT=ws://localhost:3000/ playwright test",
		"e2e:docker:ui": "PW_TEST_CONNECT_WS_ENDPOINT=ws://localhost:3000/ playwright test --ui",
		"e2e:ui": "playwright test --ui",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"stylelint": "stylelint 'assets/**/*.{css,scss}'",
		"stylelint:fix": "stylelint 'assets/**/*.{css,scss}' --fix",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@microsoft/fast-element": "catalog:",
		"@microsoft/fast-web-utilities": "catalog:",
		"@repo/styles": "workspace:*",
		"@vonage/vivid": "workspace:*",
		"@vonage/vivid-icons": "workspace:*",
		"@vonage/vivid-test-utils": "workspace:*",
		"@vonage/vivid-vue": "workspace:*",
		"lodash": "^4.17.23",
		"ramda": "catalog:"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-vite": "^7.0.0",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/language": "^6.12.2",
		"@codemirror/state": "^6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.39.16",
		"@playwright/test": "catalog:",
		"@repo/eslint-config": "workspace:*",
		"@repo/shared": "workspace:*",
		"@repo/stylelint-config": "workspace:*",
		"@repo/tokens": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/vitest-config": "workspace:*",
		"@types/jsdom": "catalog:",
		"@types/lodash": "^4.17.24",
		"@types/markdown-it": "^14.1.0",
		"@types/ramda": "catalog:",
		"@vitejs/plugin-vue": "catalog:",
		"clean-css": "^5.3.3",
		"codemirror": "^6.0.2",
		"concurrently": "catalog:",
		"eleventy-plugin-nesting-toc": "^1.3.0",
		"esbuild": "^0.25.12",
		"glob": "catalog:",
		"highlight.js": "^11.11.1",
		"htmx.org": "^2.0.0",
		"http-server": "catalog:",
		"jsdom": "^28.1.0",
		"markdown-it": "^14.0.0",
		"markdown-it-anchor": "^9.0.0",
		"pagefind": "^1.4.0",
		"sass": "catalog:",
		"slugify": "^1.6.6",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"vitest-axe": "catalog:",
		"vue": "catalog:vue3",
		"wait-on": "catalog:"
	}
}
