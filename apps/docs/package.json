{
	"name": "@repo/docs",
	"private": true,
	"scripts": {
		"prebuild": "rm -rf .11ty-vite dist",
		"build": "eleventy",
		"postbuild": "pagefind --site dist",
		"predev": "rm -rf .11ty-vite dist",
		"dev": "eleventy --serve",
		"e2e": "playwright test",
		"e2e:docker": "PW_TEST_CONNECT_WS_ENDPOINT=ws://localhost:3000/ playwright test",
		"e2e:docker:ui": "PW_TEST_CONNECT_WS_ENDPOINT=ws://localhost:3000/ playwright test --ui",
		"e2e:ui": "playwright test --ui",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"stylelint": "stylelint 'assets/**/*.{css,scss}'",
		"stylelint:fix": "stylelint 'assets/**/*.{css,scss}' --fix",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@microsoft/fast-element": "catalog:",
		"@microsoft/fast-web-utilities": "catalog:",
		"@repo/consts": "workspace:*",
		"@repo/styles": "workspace:*",
		"@vonage/vivid": "workspace:*",
		"@vonage/vivid-test-utils": "workspace:*",
		"@vonage/vivid-vue": "workspace:*",
		"lodash": "catalog:",
		"ramda": "catalog:"
	},
	"devDependencies": {
		"@11ty/eleventy": "catalog:",
		"@11ty/eleventy-navigation": "catalog:",
		"@11ty/eleventy-plugin-vite": "catalog:",
		"@codemirror/lang-html": "catalog:",
