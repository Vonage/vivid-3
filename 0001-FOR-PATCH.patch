+		expect(domRect.width).toBe(200);
+		expect(domRect.height).toBe(200);
+		expect(domRect.top).toBe(100);
+		expect(domRect.right).toBe(300);
+		expect(domRect.bottom).toBe(300);
+		expect(domRect.left).toBe(100);
